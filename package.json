{
  "name": "brella",
  "version": "0.1.0-alpha",
  "description": "AI 出片策展 Agent — B→D→D 交互协议引擎",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "brella": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/api/public && cp -r src/api/public dist/api/",
    "start": "node dist/cli.js",
    "serve": "node dist/api/server.js",
    "serve:prod": "node dist/api/server.js --port 8898 --db /opt/data/workspace/brella.db",
    "serve:daemon": "nohup node dist/api/server.js --port 8898 --db /opt/data/workspace/brella.db > /opt/data/logs/brella.log 2>&1 &",
    "dev": "tsx watch src/cli.ts",
    "dev:server": "tsx watch src/api/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
