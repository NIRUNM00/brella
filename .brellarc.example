# Brella Configuration — AI 出片策展 Agent
#
# 配置加载链（高→低）:
#   1. CLI 参数     --port 8899 --db /path/to/brella.db
#   2. 环境变量     BRELLA_PORT / BRELLA_DB_PATH / BRELLA_CONFIG
#   3. 本配置文件   ./.brellarc（JSON 或此 YAML 格式）
#   4. 用户配置     ~/.brellarc
#   5. 默认值       端口 8898 / 当前目录 ./brella.db
#
# 复制此文件为 .brellarc（或 .brellarc.json）并修改

# API 服务端口
port: 8898

# SQLite 数据库路径（绝对或相对于工作目录）
db_path: /opt/data/workspace/brella.db
# 或 JSON 等效格式:
# dbPath: /opt/data/workspace/brella.db
# database:
#   path: /opt/data/workspace/brella.db
# server:
#   port: 8898
